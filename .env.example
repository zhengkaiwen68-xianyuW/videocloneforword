# MiniMax API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT=60

# Bilibili (从浏览器开发者工具获取)
BILIBILI_COOKIE=SESSDATA=your_sessdata_here
BILIBILI_ACCESS_TOKEN=

# CORS (可选，逗号分隔)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web 前端 (可选；默认通过 Vite 代理访问 /v1)
# VITE_API_BASE_URL=/v1

# 并发控制 (可选，覆盖 config.yaml 中的默认值)
# MAX_CONCURRENT_TASKS=3
# MAX_CONCURRENT_LLM=5
# MAX_CONCURRENT_DOWNLOADS=2
# API_RATE_LIMIT=60

# RAG 向量检索 (可选，覆盖 config.yaml 中的默认值)
# RAG_CHROMA_PATH=./data/chroma_db
# RAG_TOP_K=5
# RAG_SIMILARITY_THRESHOLD=0.6
